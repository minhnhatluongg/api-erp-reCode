# =============================================================
# ERP Portal API - Environment Variables Template
# Copy file này thành `.env` và điền giá trị thật.
# KHÔNG commit file `.env` lên git!
# =============================================================

# ---- JWT ----
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-chars
JWT_ISSUER=ERPPortalAPI
JWT_AUDIENCE=ERPPortalClient

# ---- SQL Server Connection Strings ----
# Định dạng: Server=host;Initial Catalog=db;User ID=user;Password=pass;TrustServerCertificate=True;
CONN_BOS_BosAccount=Server=YOUR_SERVER;Initial Catalog=BosAccount;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosApproval=Server=YOUR_SERVER;Initial Catalog=BosApproval;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosAsset=Server=YOUR_SERVER;Initial Catalog=BosAsset;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosCataloge=Server=YOUR_SERVER;Initial Catalog=BosCataloge;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosConfigure=Server=YOUR_SERVER;Initial Catalog=BosConfigure;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosDocument=Server=YOUR_SERVER;Initial Catalog=BosDocument;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosEVAT=Server=YOUR_SERVER;Initial Catalog=BosEVAT;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosHumanResource=Server=YOUR_SERVER;Initial Catalog=BosHumanResource;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosInfo=Server=YOUR_SERVER;Initial Catalog=BosInfo;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosInventory=Server=YOUR_SERVER;Initial Catalog=BosInventory;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosManufacture=Server=YOUR_SERVER;Initial Catalog=BosManufacture;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosOnline=Server=YOUR_SERVER;Initial Catalog=BosOnline;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosSales=Server=YOUR_SERVER;Initial Catalog=BosSales;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosSupply=Server=YOUR_SERVER;Initial Catalog=BosSupply;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosWarehouseData=Server=YOUR_SERVER;Initial Catalog=BosWarehouseData;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosEVATExt=Server=YOUR_SERVER;Initial Catalog=BosTVAN;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_Bos235=Server=YOUR_SERVER;Initial Catalog=BosTVAN;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_BOS_BosControlEVAT=Server=YOUR_SERVER;Initial Catalog=BosControlEVAT;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;
CONN_Server234=Server=YOUR_SERVER;Initial Catalog=BosCataloge;User ID=USER;Password=PASSWORD;TrustServerCertificate=True;

# ---- SMTP Settings ----
SMTP_HOST=mail.win-tech.vn
SMTP_PORT=25
SMTP_SENDER_EMAIL=noreply@win-tech.vn
SMTP_SENDER_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_RECEIVER_KETOAN=ketoanhoadondientu@win-tech.vn
PORTAL_BASE_URL=http://www.winerp.org:8081

# ---- AppSettings ----
APP_BASE_URL=https://api-erprc.win-tech.vn/
APP_API_USER=sign_app_user
APP_API_PASSWORD=YOUR_APP_API_PASSWORD

# ---- File Config ----
FILE_PHYSICAL_ROOT_PATH=/app/Attachments
FILE_BASE_URL=https://api-erprc.win-tech.vn

# ---- EContract Log Config ----
ECONTRACT_LOG_PATH=/app/Logs/EContract
ECONTRACT_LOG_RETENTION_DAYS=14

# ---- WebApp ----
WEBAPP_BASE_URL=https://quanly.wininvoice.vn/
WEBAPP_AUTH_USER=monet-register
WEBAPP_AUTH_PASS=YOUR_WEBAPP_AUTH_PASS

# ---- DB Credentials (mã hóa) ----
DB_CRED_USER=YOUR_ENCRYPTED_USER
DB_CRED_PASSWORD=YOUR_ENCRYPTED_PASSWORD

# ---- WinInvoice ----
WIN_INVOICE_BASE_URL=https://demo.evat.vn
WIN_INVOICE_CLIENT_ID=YOUR_CLIENT_ID
WIN_INVOICE_CLIENT_SECRET=YOUR_CLIENT_SECRET
WIN_INVOICE_INV_NAME=1
WIN_INVOICE_INV_SERIAL=C26TAT

# ---- ERP Portal ----
ERP_PORTAL_BASE_URL=https://api-erprc.win-tech.vn

# ---- HR Account API ----
HR_ACCOUNT_BASE_URL=https://be-erp.lotviet.com:8433
HR_ACCOUNT_API_KEY=YOUR_HR_API_KEY

# ---- HTTPS Cert (nếu dùng HTTPS trực tiếp trong container) ----
# CERT_PASSWORD=YOUR_PFX_PASSWORD
